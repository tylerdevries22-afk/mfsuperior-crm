{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/tick-sequences",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/poll-replies",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/validate-emails",
      "schedule": "0 7 * * 0"
    },
    {
      "path": "/api/cron/sync-drive",
      "schedule": "0 */4 * * *"
    }
  ]
}
