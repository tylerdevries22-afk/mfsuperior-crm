# ─────────────────────────────────────────────────────────────────────────
# MF Superior CRM — environment template
#
# Single source of truth: src/lib/env.ts (zod schema)
# Workflow:
#   1. cp .env.example .env.local
#   2. Fill in the REQUIRED values
#   3. npm run env:check          # validates .env.local against the schema
#   4. vercel env pull .env.local # (optional) sync from Vercel into local
# ─────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────

# Postgres URL (Neon pooler in production). Must be a valid URL.
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# openssl rand -base64 32  (min 32 chars)
AUTH_SECRET=""

# Google OAuth client (Gmail + Drive + Calendar share one client)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Public origin of the deployed app. Used for redirect URLs, tracking pixels,
# unsubscribe links, and the contact-form CRM link.
# Local: http://localhost:3000
# Production: https://your-domain.com (no trailing slash)
APP_URL="http://localhost:3000"

# Cron auth (must match Authorization: Bearer <CRON_SECRET> on /api/cron/* hits)
# openssl rand -hex 16  (min 16 chars)
CRON_SECRET=""

# Used to AES-encrypt OAuth refresh tokens at rest.
# openssl rand -base64 32  (min 32 chars)
ENCRYPTION_KEY=""

# Sender identity (used in compliance footer + email signatures)
BUSINESS_NAME="MF Superior Solutions"
BUSINESS_ADDRESS="15321 E Louisiana Ave, Aurora, CO 80017, United States"

# ── Optional ─────────────────────────────────────────────────────────────

# Resend (transactional email) — leave blank to use Gmail-only sending in dev
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""

# Gmail mailbox the CRM operates from (defaults to the signed-in user)
GMAIL_USER=""

# Google Drive folder ID for the canonical lead workbook sync
DRIVE_FOLDER_ID=""

# Sender identity (continued, optional)
BUSINESS_MC=""
BUSINESS_USDOT=""

# Sending limits (numeric; defaults applied if unset)
DAILY_SEND_CAP="20"
WARMUP_DAYS="7"
WARMUP_DAILY_CAP="5"

# Auth.js v5 (Vercel auto-detects, set explicitly only on a custom domain)
# AUTH_URL="https://your-domain.com"
# AUTH_TRUST_HOST="true"

# ── Lead research script (scripts/research-leads.ts) ─────────────────────
# Used only by the offline lead-research script — not read at request time.
#
# Google Cloud Console → APIs & Services → Credentials → Create API Key.
# Restrict to: Places API (New), HTTP referrer = none, IP = your machine.
GOOGLE_MAPS_API_KEY=""
# hunter.io → Settings → API → API key. Free tier: 25 searches + 25
# verifications/month. Starter ($49/mo) unlocks 500 + 1,000.
HUNTER_API_KEY=""
